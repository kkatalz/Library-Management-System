generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Book {
  id        String  @id @default(uuid())
  title     String
  author    String
  year      Int
  isbn      String  @unique
  available Boolean @default(true)

  loans Loan[]
}

enum UserRole { 
  USER
  ADMIN
}

model User {
  id           String @id @default(uuid())
  name         String
  email        String @unique
  passwordHash String 
  role         UserRole @default(USER)

  loans Loan[]
}

 enum LoanStatus {
    ACTIVE
    RETURNED
  }

model Loan {
  id         String   @id @default(uuid())
  loanDate   DateTime @default(now())
  returnDate DateTime?
  status     LoanStatus @default(ACTIVE)

  book   Book   @relation(fields: [bookId], references: [id])
  bookId String

  user   User   @relation(fields: [userId], references: [id])
  userId String
}
